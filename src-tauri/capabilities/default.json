{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:default",
    "core:webview:allow-webview-close",
    "core:webview:allow-create-webview",
    "shell:allow-execute",
    "shell:allow-spawn",
    "notification:default",
    "store:default"
  ]
}

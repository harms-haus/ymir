{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:default",
    "core:webview:allow-webview-close",
    "core:webview:allow-create-webview",
    "shell:allow-execute",
    "shell:allow-spawn",
    "notification:default",
    "store:default",
    "allow-spawn_pty",
    "allow-write_pty",
    "allow-resize_pty",
    "allow-kill_pty",
    "allow-create_pane_in_workspace",
    "allow-close_pane",
    "allow-focus_pane",
    "allow-get_pane_cwd",
    "allow-set_environment_context",
    "allow-is_pty_alive",
    "allow-attach_pty_channel",
    "allow-kill_all_sessions",
    "allow-exit_app",
    "allow-get_app_cwd",
    "allow-get_git_status",
    "allow-stage_file",
    "allow-unstage_file",
    "allow-discard_file_changes",
    "allow-commit_changes",
    "allow-get_branches",
    "allow-create_branch",
    "allow-delete_branch",
    "allow-checkout_branch",
    "allow-discover_git_repos"
  ]
}
